# Perplexity API Key for AI Summarization
# Get your API key from: https://www.perplexity.ai/settings/api
EXPO_PUBLIC_PERPLEXITY_API_KEY=your_api_key_here

# Sentry DSN for crash reporting (optional but recommended for beta)
# Get your DSN from: https://sentry.io/organizations/<your-org>/projects/
EXPO_PUBLIC_SENTRY_DSN=

# Optional feedback form URL (used when email composer is unavailable)
EXPO_PUBLIC_FEEDBACK_FORM_URL=
