{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "dev: Expo start (JS Debug Terminal)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm start",
            "cwd": "${workspaceFolder}",
            "presentation": { "order": 1, "group": "development" }
        },
        {
            "name": "dev: Expo start (clear cache)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx expo start --clear",
            "cwd": "${workspaceFolder}",
            "presentation": { "order": 2, "group": "development" }
        },
        {
            "name": "dev: Expo start (web)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx expo start --web",
            "cwd": "${workspaceFolder}",
            "presentation": { "order": 3, "group": "development" }
        },
        {
            "name": "dev: Expo run:ios (native build)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx expo run:ios",
            "cwd": "${workspaceFolder}",
            "presentation": { "order": 4, "group": "development" }
        },
        {
            "name": "dev: Expo run:android (native build)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx expo run:android",
            "cwd": "${workspaceFolder}",
            "presentation": { "order": 5, "group": "development" }
        },
        {
            "name": "attach: Metro (Hermes)",
            "type": "pwa-node",
            "request": "attach",
            "port": 19000,
            "cwd": "${workspaceFolder}",
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "presentation": { "order": 6, "group": "debugging" }
        },
        {
            "name": "debug: Chrome Remote JS",
            "type": "pwa-chrome",
            "request": "attach",
            "port": 9222,
            "urlFilter": "*localhost:8081*",
            "presentation": { "order": 7, "group": "debugging" }
        }
    ],
    "compounds": [
        {
            "name": "Expo: start + attach",
            "configurations": [
                "dev: Expo start (JS Debug Terminal)",
                "attach: Metro (Hermes)"
            ]
        }
    ]
}
