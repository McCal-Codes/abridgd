{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Expo",
            "type": "pwa-node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/expo",
            "args": ["start"],
            "skipFiles": ["<node_internals>/**"],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Attach to Packager",
            "type": "node",
            "request": "attach",
            "port": 19000,
            "sourceMaps": true
        }
    ]
}